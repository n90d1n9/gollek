# Gollek CLI Build
# Includes: Core, SPI, SDK, runners, models, and CLI

BACKEND_TARGETS="cpu,metal"
FORMAT_TARGETS="gguf,litert,onnx,safetensor"
LLM_TARGETS="text,vision"
ARCHITECTURE_TARGETS="binding,native-java"
ARCHITECTURE_TARGET="binding,native-java"
BUILD_PROFILE="release"
RESOLVED_BACKEND_PROPERTY="cpu,metal"

# Full module list required to build the CLI uber-jar
MODULES="\
:core:gollek-error-code \
:core:gollek-ir \
:core:gollek-ir-schema \
:core:gollek-adapter \
:core:gollek-core \
:core:gollek-model-database \
:core:gollek-model-repo-hf \
:core:gollek-model-repo-kaggle \
:core:gollek-model-repo-local \
:core:gollek-model-repository \
:core:gollek-model-runner \
:core:gollek-observability \
:core:gollek-multitenancy \
:core:gollek-provider-core \
:core:gollek-provider-routing \
:core:gollek-runtime-config \
:core:gollek-tokenizer-core \
:core:gollek-tool-core \
:core:plugin:gollek-plugin-core \
:core:plugin:gollek-plugin-kernel-core \
:core:plugin:gollek-plugin-runner-core \
:spi:gollek-spi \
:spi:gollek-spi-inference \
:spi:gollek-spi-model \
:spi:gollek-spi-multimodal \
:spi:gollek-spi-plugin \
:spi:gollek-spi-provider \
:spi:gollek-spi-runtime \
:sdk:gollek-sdk \
:sdk:gollek-sdk-agent \
:sdk:gollek-sdk-api \
:sdk:gollek-sdk-core \
:sdk:gollek-sdk-local \
:runner:safetensor:gollek-safetensor-spi \
:runner:safetensor:gollek-safetensor-core \
:runner:safetensor:gollek-safetensor-api \
:runner:safetensor:gollek-safetensor-loader \
:runner:safetensor:gollek-safetensor-quantization \
:runner:safetensor:gollek-safetensor-engine \
:runner:gguf:gollek-gguf-core \
:runner:litert:gollek-runner-litert \
:runner:onnx:gollek-runner-onnx \
:models:gollek-model-gemma4 \
:models:gollek-model-qwen3-moe \
:models:gollek-model-qwen3-5-moe \
:plugins:gollek-plugin-mcp \
:plugins:log-parser \
:optimization:gollek-plugin-kv-cache \
:ui:gollek-cli"

# Modules that use quarkusBuild instead of standard build
QUARKUS_MODULES=":ui:gollek-cli"

WARNINGS=""
SCRIPT_SLUG="gollek-cli"
