# Minimal gollek build - inference only
# Only includes modules that actually exist in this gollek checkout

BACKEND_TARGETS="cpu,metal"
FORMAT_TARGETS="gguf,litert,onnx,safetensor"
LLM_TARGETS="text,vision"
ARCHITECTURE_TARGETS="binding,native-java"
ARCHITECTURE_TARGET="binding,native-java"
BUILD_PROFILE="release"
RESOLVED_BACKEND_PROPERTY="cpu,metal"

# Minimal module list - core inference modules only
# Excludes: tensor, ml, training, runners, models, diffuser, etc.
MODULES=":core:gollek-error-code :core:gollek-ir :core:gollek-ir-schema :core:gollek-adapter :core:gollek-core :core:gollek-model-repository :core:gollek-model-runner :core:gollek-provider-core :core:gollek-provider-routing :core:gollek-runtime-config :core:gollek-tokenizer-core :core:gollek-tool-core :core:gollek-observability :core:gollek-multitenancy :core:plugin:gollek-plugin-core :core:plugin:gollek-plugin-kernel-core :spi:gollek-spi :spi:gollek-spi-inference :spi:gollek-spi-model :spi:gollek-spi-plugin :spi:gollek-spi-provider :spi:gollek-spi-runtime :sdk:gollek-sdk :sdk:gollek-sdk-core :sdk:gollek-sdk-api :sdk:gollek-sdk-local"

WARNINGS="Minimal build - core inference only, excludes training/models/export"
SCRIPT_SLUG="minimal-inference-core"
