{
  "id": "openai-cloud-provider",
  "name": "OpenAI Cloud Provider",
  "version": "1.0.0",
  "description": "Cloud provider for OpenAI models (GPT-4, GPT-3.5-turbo, etc.)",
  "provider": "Kayys.tech",
  "mainClass": "tech.kayys.gollek.plugin.cloud.openai.OpenAiCloudProvider",
  "dependencies": [
    "tech.kayys:gollek-spi-plugin:1.0.0-SNAPSHOT",
    "tech.kayys:gollek-spi-provider:1.0.0-SNAPSHOT",
    "tech.kayys:gollek-spi-inference:1.0.0-SNAPSHOT"
  ],
  "capabilities": [
    "cloud-provider",
    "streaming",
    "function-calling",
    "llm"
  ],
  "config": {
    "apiKey": {
      "type": "string",
      "required": true,
      "description": "OpenAI API key (sk-...)",
      "sensitive": true
    },
    "baseUrl": {
      "type": "string",
      "required": false,
      "default": "https://api.openai.com/v1",
      "description": "Custom API endpoint"
    },
    "organization": {
      "type": "string",
      "required": false,
      "description": "OpenAI organization ID"
    },
    "maxTokens": {
      "type": "number",
      "required": false,
      "default": "4096",
      "description": "Default maximum tokens for completions"
    },
    "temperature": {
      "type": "number",
      "required": false,
      "default": "0.7",
      "description": "Default temperature for completions"
    }
  },
  "models": [
    {
      "id": "gpt-4",
      "name": "GPT-4",
      "contextLength": 8192,
      "description": "Most capable GPT-4 model"
    },
    {
      "id": "gpt-4-turbo",
      "name": "GPT-4 Turbo",
      "contextLength": 128000,
      "description": "Faster GPT-4 with larger context"
    },
    {
      "id": "gpt-4-32k",
      "name": "GPT-4 32K",
      "contextLength": 32768,
      "description": "GPT-4 with 32K context window"
    },
    {
      "id": "gpt-3.5-turbo",
      "name": "GPT-3.5 Turbo",
      "contextLength": 4096,
      "description": "Fast and efficient GPT-3.5 model"
    },
    {
      "id": "gpt-3.5-turbo-16k",
      "name": "GPT-3.5 Turbo 16K",
      "contextLength": 16384,
      "description": "GPT-3.5 with larger context window"
    }
  ],
  "features": {
    "streaming": true,
    "functionCalling": true,
    "vision": false,
    "fineTuning": true,
    "embeddings": true
  },
  "rateLimits": {
    "requestsPerMinute": 10000,
    "tokensPerMinute": 1000000
  },
  "healthCheck": {
    "endpoint": "/v1/models",
    "method": "GET",
    "interval": 60
  }
}