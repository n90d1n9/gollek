<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>tech.kayys.gollek</groupId>
        <artifactId>gollek-optimization-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>gollek-plugin-fa3</artifactId>
    <name>Gollek Plugin :: FlashAttention-3</name>
    <description>FlashAttention-3 optimization plugin for Hopper+ GPUs</description>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
    </properties>

    <dependencies>
        <!-- Core optimization SPI -->
        <dependency>
            <groupId>tech.kayys.gollek</groupId>
            <artifactId>gollek-plugin-optimization-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- JNA for native binding -->
        <dependency>
            <groupId>net.java.dev.jna</groupId>
            <artifactId>jna</artifactId>
            <version>5.14.0</version>
        </dependency>

        <!-- Gollek SPI for domain types -->
        <dependency>
            <groupId>tech.kayys.gollek</groupId>
            <artifactId>gollek-spi-provider</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Quarkus Core -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-arc</artifactId>
            <version>3.32.2</version>
        </dependency>

        <!-- Mutiny for streaming -->
        <dependency>
            <groupId>io.smallrye.reactive</groupId>
            <artifactId>mutiny</artifactId>
            <version>2.9.4</version>
        </dependency>

        <!-- Logging -->
        <dependency>
            <groupId>org.jboss.logging</groupId>
            <artifactId>jboss-logging</artifactId>
            <version>3.6.1.Final</version>
            <scope>provided</scope>
        </dependency>

        <!-- Testing -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.11.4</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>3.27.3</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.4.2</version>
                <configuration>
                    <archive>
                        <manifest>
                            <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
                        </manifest>
                        <manifestEntries>
                            <!-- Required -->
                            <Plugin-Id>flash-attention-3</Plugin-Id>
                            <Plugin-Type>optimization</Plugin-Type>
                            <Plugin-Version>${project.version}</Plugin-Version>
                            <Plugin-Name>FlashAttention-3</Plugin-Name>
                            <Plugin-Provider>tech.kayys.gollek.plugin.optimization.fa3.FlashAttention3Plugin</Plugin-Provider>
                            
                            <!-- Capabilities -->
                            <Plugin-Capabilities>flash-attention-3, optimized-attention, gpu-optimization</Plugin-Capabilities>
                            
                            <!-- Dependencies -->
                            <Plugin-Dependencies>cuda-kernel</Plugin-Dependencies>
                            
                            <!-- Deployment modes -->
                            <Plugin-Deployment>microservice,hybrid</Plugin-Deployment>
                            
                            <!-- Metadata -->
                            <Plugin-Author>Gollek Team</Plugin-Author>
                            <Plugin-Vendor>Kayys.tech</Plugin-Vendor>
                            <Plugin-License>MIT</Plugin-License>
                            
                            <!-- GPU Requirements -->
                            <Plugin-GPU-Requirement>NVIDIA Hopper+ (H100), CUDA 12.0+</Plugin-GPU-Requirement>
                            <Plugin-Minimum-Compute-Capability>9.0</Plugin-Minimum-Compute-Capability>
                            <Plugin-Minimum-Memory>16GB</Plugin-Minimum-Memory>
                            
                            <!-- Performance -->
                            <Plugin-Performance-Speedup>2-3x (vs standard attention)</Plugin-Performance-Speedup>
                            <Plugin-Performance-Memory-Overhead>100-200MB</Plugin-Performance-Memory-Overhead>
                            
                            <!-- GPU Architecture -->
                            <GPU-Arch>hopper,blackwell</GPU-Arch>
                            <CUDA-Compute-Capability>9.0</CUDA-Compute-Capability>
                        </manifestEntries>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>