# Gollek SafeTensor Runner v2 - Example Configuration
# Copy this to your application.properties and adjust as needed

# ════════════════════════════════════════════════════════════════════════════
# Text-to-Speech Configuration
# ════════════════════════════════════════════════════════════════════════════

# Default voice for TTS (alloy | echo | fable | onyx | nova | shimmer)
gollek.audio.tts.default-voice=alloy

# ════════════════════════════════════════════════════════════════════════════
# Model Hot-Swap Configuration
# ════════════════════════════════════════════════════════════════════════════

# Enable zero-downtime model hot-swap
gollek.hotswap.enabled=true

# Drain timeout for in-flight requests during hot-swap (seconds)
gollek.hotswap.drain-timeout-s=30

# ════════════════════════════════════════════════════════════════════════════
# Memory Monitoring Configuration
# ════════════════════════════════════════════════════════════════════════════

# Memory pressure threshold (ratio 0.0-1.0)
gollek.memory.pressure.threshold=0.85

# Memory check interval (seconds)
gollek.memory.check.interval-s=5

# ════════════════════════════════════════════════════════════════════════════
# RAG / Qdrant Configuration
# ════════════════════════════════════════════════════════════════════════════

# Qdrant vector database URL
gollek.rag.qdrant.url=http://localhost:6333

# Qdrant API key (for Qdrant Cloud)
gollek.rag.qdrant.api-key=

# Qdrant request timeout (seconds)
gollek.rag.qdrant.timeout-s=30

# ════════════════════════════════════════════════════════════════════════════
# Graceful Shutdown Configuration
# ════════════════════════════════════════════════════════════════════════════

# Shutdown timeout (seconds)
gollek.shutdown.timeout-s=30

# Quiet period before shutdown (seconds)
gollek.shutdown.quiet-period-s=5

# ════════════════════════════════════════════════════════════════════════════
# SafeTensor Bridge Configuration
# ════════════════════════════════════════════════════════════════════════════

# Enable native FP8 support on H100 (future feature)
# gollek.safetensor.bridge.fp8.native=false

# ════════════════════════════════════════════════════════════════════════════
# Generation Configuration
# ════════════════════════════════════════════════════════════════════════════

# Default max tokens for generation
# gollek.generation.max-tokens=2048

# Default temperature for sampling
# gollek.generation.temperature=0.7

# Default top-p for nucleus sampling
# gollek.generation.top-p=0.9

# ════════════════════════════════════════════════════════════════════════════
# Session Management Configuration
# ════════════════════════════════════════════════════════════════════════════

# Maximum tokens per conversation session
# gollek.session.max-tokens-per-session=4096

# Session idle timeout (minutes)
# gollek.session.idle-timeout-minutes=30
