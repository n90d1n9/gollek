<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>tech.kayys</groupId>
  <artifactId>trellis2-java</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>TRELLIS.2 Java</name>
  <description>
    Java 25 port of Microsoft TRELLIS.2 — Native and Compact Structured Latents
    for 3D Generation. Uses JDK 25 FFM API (JEP 454) for zero-copy native
    access to CUDA kernels (FlexGEMM, o_voxel, nvdiffrast).
  </description>

  <properties>
    <java.version>25</java.version>
    <maven.compiler.source>25</maven.compiler.source>
    <maven.compiler.target>25</maven.compiler.target>
    <maven.compiler.release>25</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <dependencies>
    <!-- SafeTensors reader (zero-copy mmap via FileChannel) -->
    <dependency>
      <groupId>ai.djl</groupId>
      <artifactId>api</artifactId>
      <version>0.29.0</version>
    </dependency>

    <!-- HuggingFace Hub download support -->
    <dependency>
      <groupId>ai.djl.huggingface</groupId>
      <artifactId>tokenizers</artifactId>
      <version>0.29.0</version>
    </dependency>

    <!-- ONNX Runtime (image encoder inference — DINOv2/SigLIP) -->
    <dependency>
      <groupId>com.microsoft.onnxruntime</groupId>
      <artifactId>onnxruntime_gpu</artifactId>
      <version>1.19.2</version>
    </dependency>

    <!-- JSON config parsing -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.18.2</version>
    </dependency>

    <!-- Logging -->
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-api</artifactId>
      <version>2.0.16</version>
    </dependency>
    <dependency>
      <groupId>ch.qos.logback</groupId>
      <artifactId>logback-classic</artifactId>
      <version>1.5.12</version>
      <scope>runtime</scope>
    </dependency>

    <!-- Test -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.11.4</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>25</release>
          <!-- Enable preview features if needed (structured concurrency stable in 25) -->
          <!-- <compilerArgs><arg>--enable-preview</arg></compilerArgs> -->
        </configuration>
      </plugin>

      <!-- Fat JAR for standalone distribution -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>tech.kayys.trellis2.Trellis2Main</mainClass>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Native image support (GraalVM 25) -->
      <plugin>
        <groupId>org.graalvm.buildtools</groupId>
        <artifactId>native-maven-plugin</artifactId>
        <version>0.10.3</version>
        <configuration>
          <imageName>trellis2</imageName>
          <mainClass>tech.kayys.trellis2.Trellis2Main</mainClass>
          <buildArgs>
            <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
            <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
          </buildArgs>
        </configuration>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <!-- CUDA GPU profile -->
    <profile>
      <id>cuda</id>
      <activation><property><name>cuda</name></property></activation>
      <properties>
        <native.lib.path>/usr/local/cuda/lib64</native.lib.path>
      </properties>
    </profile>

    <!-- CPU-only profile (no CUDA, all Java fallbacks) -->
    <profile>
      <id>cpu</id>
      <activation><activeByDefault>true</activeByDefault></activation>
      <properties>
        <native.lib.path></native.lib.path>
      </properties>
    </profile>
  </profiles>
</project>
